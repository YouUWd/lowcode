                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"permissions\": [\n    \"hr_employee_base.emp_no.SELECT\",\n    \"hr_employee_base.first_name.SELECT\",\n    \"hr_employee_base.last_name.SELECT\",\n    \"hr_emp_personal.id_card_no.SELECT\",\n    \"hr_emp_job.emp_type.SELECT\",\n    \"hr_organization.org_name.SELECT\",\n    \"hr_employee_base.status.SELECT\"\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/permissions/config",
                  "host": ["{{baseUrl}}"],
                  "path": ["permissions", "config"]
                }
              }
            },
            {
              "name": "2. Query (All Fields)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/query/MOD-HR-EMP",
                  "host": ["{{baseUrl}}"],
